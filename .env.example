# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rdswa

# JWT
JWT_ACCESS_SECRET=your-access-secret-key
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=365d

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=RDSWA <noreply@rdswa.org>

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Client (production only — leave empty for dev, Vite proxy handles it)
# VITE_API_URL: API base URL (not needed if Vercel rewrites proxy /api)
VITE_API_URL=
# VITE_SOCKET_URL: WebSocket server URL (required in production for Socket.io)
# Example: https://rdswa.onrender.com
VITE_SOCKET_URL=

# Sentry (optional — leave blank to disable error tracking)
SENTRY_DSN=
VITE_SENTRY_DSN=

# Google AdSense — the publisher ID for rdswa.info.bd.
# This value is PUBLIC (visible in every served page's HTML), not a secret —
# committed to .env.example so a fresh clone has a working production config.
# Leave the value EMPTY in your local client/.env to keep dev consoles clean
# (no adsbygoogle.js network requests, no AdSense impressions counted in dev).
# Production (Vercel) MUST have this set, otherwise no ads will serve.
VITE_ADSENSE_CLIENT=ca-pub-1036044341182474

# Microsoft Clarity — free user-behaviour analytics (session recordings,
# heatmaps, click maps). The project ID is a 10-character alphanumeric
# string issued by clarity.microsoft.com when you create a project. It
# is PUBLIC (visible in every served page's HTML), not a secret.
# The env-gated loader in client/index.html only fires Clarity when this
# is set — leave empty in dev so local sessions don't pollute production
# recordings. Set this in Vercel for production deployments.
# Find it at: clarity.microsoft.com → your project → Settings → Overview.
VITE_CLARITY_PROJECT_ID=
